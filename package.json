{
  "name": "windswill-base",
  "version": "0.1.0-draft",
  "private": true,
  "type": "module",
  "description": "Offline-first application foundation. Clone it, rename things, and start building.",
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "dev:web": "pnpm --filter web run dev",
    "dev:local": "pnpm --filter local run dev",
    "build": "pnpm -r run build",
    "build:web": "pnpm --filter web run build",
    "build:desktop": "pnpm --filter desktop run build",
    "build:docker": "pnpm --filter local run build && docker build -t windswill-app .",
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r run test",
    "test:e2e": "playwright test",
    "generate:feature": "plop feature",
    "generate:theme": "plop theme",
    "generate:model": "plop model",
    "setup": "node scripts/setup.js"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "lefthook": "^1.6.0",
    "playwright": "^1.45.0",
    "plop": "^4.0.0",
    "prettier": "^3.4.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0"
}