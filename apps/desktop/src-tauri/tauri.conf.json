{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "windswill",
  "identifier": "com.windswill.app",
  "build": {
    "beforeBuildCommand": "pnpm --filter web build",
    "beforeDevCommand": "pnpm --filter web dev",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../web/dist"
  },
  "app": {
    "windows": [
      {
        "title": "windswill",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}